@startuml

!theme plain
top to bottom direction
skinparam linetype ortho

abstract class VideoClass {
  + VideoClass(String, int, String)
  + VideoClass(String)
  - id: String
  - duration: int
  - videoLocation: String
  + getId(): String
  + getDuration(): int
  + getVideoLocation(): String
  + equals(Object): boolean
  + hashCode(): int
}

interface Video << interface >> {
  + getId(): String
  + getDuration(): int
  + getVideoLocation(): String
}

interface PublishableVideo << interface >> {
  + getTitle(): String
  + getPublisher(): String
  + getLanguage(): Locale
}

class PublishableVideoClass {
  + PublishableVideoClass(String, int, String, String, String, Locale)
  + PublishableVideoClass(String)
  - title: String
  - publisher: String
  - language: Locale
  + getTitle(): String
  + getPublisher(): String
  + getLanguage(): Locale
}

interface PremiumVideo << interface >> {
  + addSubtitle(Subtitle): void
  + getSubtitles(): Iterator<Subtitle>
}

class PremiumVideoClass {
  + PremiumVideoClass(String, int, String, String, String, Locale, Subtitle)
  - subtitles: Array<Subtitle>
  - addInitialSubtitle(Subtitle): void
  + addSubtitle(Subtitle): void
  + getSubtitles(): Iterator<Subtitle>
}

interface Episode << interface >> {
  + getDate(): String
}

class EpisodeClass {
  + EpisodeClass(String, int, String, String)
  + EpisodeClass(String)
  - date: String
  + getDate(): String
}

interface Podcast << interface >> {
  + getTitle(): String
  + getAuthor(): String
  + getLanguage(): Locale
  + addEpisode(Episode): void
  + getEpisodes(): Iterator<Episode>
  + hasEpisodes(): boolean
  + isUnique(String): boolean
  + isNewer(String): boolean
  + getLastestDate(): String
}

class PodcastClass {
  + PodcastClass(String, String, Locale)
  + PodcastClass(String)
  - title: String
  - author: String
  - language: Locale
  - episodes: Array<Episode>
  + getTitle(): String
  + getAuthor(): String
  + getLanguage(): Locale
  + addEpisode(Episode): void
  + getEpisodes(): Iterator<Episode>
  + hasEpisodes(): boolean
  + isUnique(String): boolean
  + isNewer(String): boolean
  + getLastestDate(): String
  + equals(Object): boolean
}

interface Show << interface >> {
  + getTitle(): String
  + getAuthor(): String
  + getDate(): String
}

class ShowClass {
  + ShowClass(String, String, String)
  + ShowClass(String)
  - title: String
  - author: String
  - date: String
  + getTitle(): String
  + getAuthor(): String
  + getDate(): String
  + equals(Object): boolean
}

class Subtitle {
  + Subtitle(Locale, String)
  - language: Locale
  - location: String
  + getLanguage(): Locale
  + getLocation(): String
}

interface YouVideoApp << interface >> {
  + addPublishable(String, int, String, String, String, Locale): void
  + addPremium(String, int, String, String, String, Locale, String, Locale): void
  + addSubtitle(String, Locale, String): void
  + addPodcast(String, String, Locale): void
  + addEpisode(String, String, int, String, String): void
  + createShow(String, String, String): void
  + removePodcast(String): void
  + removeShow(String): void
  + removeVideo(String): void
  + getVideo(String): PublishableVideo
  + getPodcast(String): Podcast
  + getShow(String): Show
  + getPodcastsByAuthor(String): Iterator<Podcast>
  + isUniqueVideo(String): boolean
  + isUniquePodcast(String): boolean
  + isUniqueEpisode(String): boolean
  + isUniqueShow(String): boolean
  + isNewer(String, String): boolean
  + isPremium(String): boolean
  + isEpisode(String): boolean
  + isVideoUsedInShow(String): boolean
  + hasEpisodesPodcast(String): boolean
  + getStoredAuthorName(String): String
}

class YouVideoAppClass {
  + YouVideoAppClass()
  - videos: Array<PublishableVideo>
  - podcasts: Array<Podcast>
  - shows: Array<Show>
  + addPublishable(String, int, String, String, String, Locale): void
  + addPremium(String, int, String, String, String, Locale, String, Locale): void
  + addSubtitle(String, Locale, String): void
  + addPodcast(String, String, Locale): void
  + addEpisode(String, String, int, String, String): void
  + createShow(String, String, String): void
  + removePodcast(String): void
  + removeShow(String): void
  + removeVideo(String): void
  + getVideo(String): PublishableVideo
  + getPodcast(String): Podcast
  + getShow(String): Show
  + getPodcastsByAuthor(String): Iterator<Podcast>
  + isUniqueVideo(String): boolean
  + isUniquePodcast(String): boolean
  + isUniqueEpisode(String): boolean
  + isUniqueShow(String): boolean
  + isNewer(String, String): boolean
  + isPremium(String): boolean
  + isEpisode(String): boolean
  + isVideoUsedInShow(String): boolean
  + hasEpisodesPodcast(String): boolean
  + getStoredAuthorName(String): String
  + isValidLanguage(String): boolean
  - findVideo(String): PublishableVideo
  - findPodcast(String): Podcast
  - findShow(String): Show
}

class Main {
  + main(String[]): void
  - readCommand(Scanner): String
  - executeCommand(String, Scanner, YouVideoApp): void
  - printHelp(): void
  - handleAddPublishable(Scanner, YouVideoApp): void
  - handleAddPremium(Scanner, YouVideoApp): void
  - handleAddSubtitle(Scanner, YouVideoApp): void
  - handleGetVideo(Scanner, YouVideoApp): void
  - handleGetSubtitles(Scanner, YouVideoApp): void
  - handleAddPodcast(Scanner, YouVideoApp): void
  - handleAddEpisode(Scanner, YouVideoApp): void
  - handleGetPodcast(Scanner, YouVideoApp): void
  - handleGetEpisodes(Scanner, YouVideoApp): void
  - handleGetAuthorPodcasts(Scanner, YouVideoApp): void
  - handleRemovePodcast(Scanner, YouVideoApp): void
  - handleCreateShow(Scanner, YouVideoApp): void
  - handleGetShow(Scanner, YouVideoApp): void
  - handleRemoveShow(Scanner, YouVideoApp): void
  - handleRemoveVideo(Scanner, YouVideoApp): void
  - printVideo(PublishableVideo, boolean): void
  - printSubtitles(PremiumVideo): void
  - printPodcast(Podcast): void
  - printEpisodes(String, Podcast): void
  - printAuthorPodcasts(String, Iterator<Podcast>): void
  - printShow(Show): void
  - toLocale(String): Locale
  - getLanguageCode(Locale): String
  - getLanguageDisplayName(Locale): String
  - printFormatted(String, String): void
}

interface Array<E> << interface >> {
  + size(): int
  + get(int): E
  + insertLast(E): void
  + insertAt(E, int): void
  + removeAt(int): void
  + removeLast(): void
  + searchForward(E): boolean
  + searchBackward(E): boolean
  + searchIndexOf(E): int
  + iterator(): Iterator<E>
}

class ArrayClass<E> {
  + ArrayClass()
  + ArrayClass(int)
  - elems: E[]
  - counter: int
  - MAX_ELEMS: int
  - FACTOR: int
  + size(): int
  + get(int): E
  + insertLast(E): void
  + insertAt(E, int): void
  + removeAt(int): void
  + removeLast(): void
  + searchForward(E): boolean
  + searchBackward(E): boolean
  + searchIndexOf(E): int
  + iterator(): Iterator<E>
  - resize(): void
}

interface Iterator<E> << interface >> {
  + hasNext(): boolean
  + next(): E
}

class ArrayIteratorClass<E> {
  + ArrayIteratorClass(E[], int)
  - elems: E[]
  - counter: int
  - current: int
  + hasNext(): boolean
  + next(): E
}

